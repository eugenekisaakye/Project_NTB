DATABASE_URL=postgresql://postgres:yourpassword@localhost/ntb_db
SECRET_KEY=replace-with-output-of-python-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_ENV=development
DEBUG=true
APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
MAX_FILES_PER_REPORT=5
